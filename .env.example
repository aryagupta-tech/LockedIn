# Optional: omit NODE_ENV here for local dev. `npm run build` forces production automatically.
# Setting NODE_ENV=development in .env could confuse tools; never required for next dev.

ADMIN_KEY=your-admin-secret-key

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=/api

# Server-side only (never prefix with NEXT_PUBLIC_ — that exposes values in the browser bundle)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local development ONLY: auto /dev-login page calls /api/dev-login (disabled when NODE_ENV=production).
# Never commit real values; never set these in Vercel for a public repo.
# DEV_LOGIN_EMAIL=you@example.com
# DEV_LOGIN_PASSWORD=your-local-dev-password

# Scoring thresholds
SCORING_PASS_THRESHOLD=70
SCORING_AUTO_APPROVE_THRESHOLD=90
SCORING_AUTO_REJECT_THRESHOLD=30

# Optional: GitHub PAT for reliable contribution totals (GraphQL); otherwise we parse the public contributions page
# GITHUB_TOKEN=

# Optional: if LeetCode returns CSRF errors from your host, paste csrftoken cookie value from leetcode.com
# LEETCODE_CSRF_TOKEN=

# Optional: secret for Codeforces "Organization" verification phrase (defaults to SUPABASE_SERVICE_ROLE_KEY)
# LOCKEDIN_VERIFICATION_SECRET=

# Optional: staging / QA — emails that exist in Supabase Auth but had no `public.users` row get one on login via ensurePublicUserRow.
# Comma-separated lists (lowercase). APPROVED = full app access; ADMIN = admin dashboard + approved.
# LOCKEDIN_SEED_APPROVED_EMAILS=test@example.com
# LOCKEDIN_SEED_ADMIN_EMAILS=qa-admin@example.com
